generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id      String  @id @default(cuid())
  name    String
  email   String  @unique
  phone   String?
  company String?

  profilClient String?
  status       String  @default("prospect")

  value       Float     @default(0)
  lastContact DateTime?
  tags        String[]
  notes       String?
  createdAt   DateTime  @default(now())
  assignedTo  String?

  activities Activity[]
  contracts  Contract[]
  deals      Deal[]
  events     Event[]
  surveys    Survey[]
  tickets    Ticket[]
}

model Deal {
  id String @id @default(cuid())

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  nomPrenom   String
  institution String?
  pays        String?
  telephone   String?
  email       String?

  typeClient    String? @default("Individuel")
  typeAdhesion  String?
  modeAdhesion  String?
  etapeAdhesion String? @default("Prospect identifié")

  documentsAttendus  String?
  documentsManquants String?

  agentResponsable String?
  service          String?
  canalAcquisition String?

  dateDemande    DateTime?
  dateValidation DateTime?
  dateActivation DateTime?

  commentaire String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  contactId String
  type      String
  date      DateTime
  note      String?
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id])
}

model Ticket {
  id         String    @id @default(cuid())
  contactId  String
  type       String
  subject    String
  status     String    @default("open")
  priority   String    @default("medium")
  createdAt  DateTime  @default(now())
  closedAt   DateTime?
  assignedTo String?
  surveys    Survey[]
  contact    Contact   @relation(fields: [contactId], references: [id])
}

model Survey {
  id          String    @id @default(cuid())
  ticketId    String
  contactId   String
  csat        Int?
  nps         Int?
  comment     String?
  sentAt      DateTime  @default(now())
  respondedAt DateTime?
  contact     Contact   @relation(fields: [contactId], references: [id])
  ticket      Ticket    @relation(fields: [ticketId], references: [id])
}

model Campaign {
  id           String   @id @default(cuid())
  name         String
  subject      String?
  content      String?
  canal        String?
  statut       String   @default("draft")

  profilClient String?
  status       String?
  tag          String?
  dateEnvoi    DateTime?

  createdAt    DateTime @default(now())
}

model Event {
  id        String   @id @default(cuid())
  title     String
  contactId String
  date      DateTime
  time      String?
  type      String
  note      String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id])
}

model Contract {
  id        String    @id @default(cuid())
  contactId String
  title     String
  status    String    @default("draft")
  startDate DateTime?
  endDate   DateTime?
  value     Float     @default(0)
  createdAt DateTime  @default(now())
  contact   Contact   @relation(fields: [contactId], references: [id])
}

model Workflow {
  id        String   @id @default(cuid())
  name      String
  trigger   String
  action    String
  active    Boolean  @default(true)
  runs      Int      @default(0)
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String   @default("agent")
  avatar       String?
  active       Boolean  @default(true)
  passwordHash String
  createdAt    DateTime @default(now())
}

model Demande {
  id                 String        @id @default(cuid())
  numDemande         String?       @unique
  nomPrenom          String
  matricule          String?
  adherent           String?
  typeClient         String        @default("Actif")
  pays               String?
  heureAppel         String?
  canal              String?
  telephone          String?
  email              String?
  objetDemande       String?
  commentaire        String?
  agentN1            String?
  service            String?
  agentN2            String?
  dateReception      DateTime?
  dateTraitement     DateTime?
  priorite           String?       @default("Moyen")
  statut             String        @default("En cours")
  actionMenee        String?
  delaiTraitement    Int?
  respectDelai       String?
  canalCommunication String?
  enqueteEnvoyee     Boolean       @default(false)
  noteSatisfaction   Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  commentaires       Commentaire[]
  timeline           Timeline[]
}

model Commentaire {
  id        String   @id @default(cuid())
  demandeId String
  auteur    String
  contenu   String
  createdAt DateTime @default(now())
  demande   Demande  @relation(fields: [demandeId], references: [id], onDelete: Cascade)
}

model Timeline {
  id        String   @id @default(cuid())
  demandeId String
  auteur    String
  action    String
  canal     String?
  detail    String?
  createdAt DateTime @default(now())
  demande   Demande  @relation(fields: [demandeId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  auteur    String
  auteurId  String?
  action    String
  entite    String
  entiteId  String?
  detail    String?
  createdAt DateTime @default(now())
}
